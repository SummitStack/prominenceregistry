---
import FathomAnalytics from '../../components/FathomAnalytics.astro';
import OrganizationSchema from '../../components/OrganizationSchema.astro';
import SeoMeta from '../../components/SeoMeta.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { SITE_URL } from '../../lib/constants';
import {
  getProminenceRankBySlug,
  peakListDefinitions,
  type PeakListDefinition,
} from '../../data/peakLists';

export function getStaticPaths() {
  return peakListDefinitions.map((definition) => ({
    params: { slug: definition.slug },
    props: { definition },
  }));
}

type Props = {
  definition: PeakListDefinition;
};

const { definition } = Astro.props as Props;
const peaks = definition.getPeaks();
const prominenceRankBySlug = getProminenceRankBySlug();
const canonical = `${SITE_URL}/lists/${definition.slug}/`;
const title = `${definition.title} | Prominence Registry`;
const description = definition.description;

const listStates = [...new Set(peaks.map((peak) => peak.state))].sort();
const listRanges = [...new Set(peaks.map((peak) => peak.mountainRange).filter(Boolean))].sort((a, b) =>
  a.localeCompare(b)
);
const listYdsClasses = [...new Set(peaks.map((peak) => peak.easiestYdsClass))].sort((a, b) => {
  const order = ['1', '2', '2+', '3', '3+', '4', '4+', '5'];
  return order.indexOf(a) - order.indexOf(b);
});

const itemListStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: definition.title,
  description,
  url: canonical,
  numberOfItems: peaks.length,
  itemListOrder: 'https://schema.org/ItemListOrderDescending',
  itemListElement: peaks.map((peak, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: peak.name,
    ...(peak.published === true ? { url: `${SITE_URL}/${peak.slug}/` } : {}),
  })),
};

function getRankLabel(index: number): string {
  return String(index + 1).padStart(2, '0');
}
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <FathomAnalytics />
  <SeoMeta title={title} description={description} canonical={canonical} />
  <OrganizationSchema />
  <script type="application/ld+json" set:html={JSON.stringify(itemListStructuredData)} />
  <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: #0f1419; color: #f0f1f3; font-family: system-ui; }
    .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
    .hero { padding: 64px 0 48px; }
    .breadcrumb { margin-bottom: 32px; font-size: 14px; color: #8b92a1; }
    .eyebrow {
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #64b5f6;
      margin-bottom: 16px;
    }
    h1 {
      font-family: 'Hanken Grotesk', system-ui, sans-serif;
      font-size: 52px;
      line-height: 1.05;
      margin-bottom: 20px;
      color: #e0e2e8;
    }
    .subtitle {
      max-width: 760px;
      font-size: 18px;
      line-height: 1.6;
      color: #c0c7d1;
      margin-bottom: 24px;
    }
    .summary { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 24px; }
    .summary-card {
      background: #1a1f27;
      border: 1px solid #2a3139;
      border-radius: 10px;
      padding: 16px 20px;
      min-width: 160px;
    }
    .summary-label {
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #8b92a1;
      margin-bottom: 6px;
    }
    .summary-value {
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      color: #64b5f6;
      font-size: 18px;
    }
    a { color: #64b5f6; text-decoration: none; }
    a:hover { text-decoration: underline; }
    .table-wrapper {
      background: #1a1f27;
      border: 1px solid #2a3139;
      border-radius: 12px;
      overflow: hidden;
      margin-bottom: 80px;
    }
    .table-header { padding: 24px; border-bottom: 1px solid #2a3139; }
    .table-header h2 {
      font-family: 'Hanken Grotesk', system-ui, sans-serif;
      font-size: 30px;
      color: #e0e2e8;
      margin-bottom: 8px;
    }
    .table-desc { color: #8b92a1; font-size: 14px; }
    .filter-bar {
      display: flex;
      flex-wrap: wrap;
      align-items: flex-end;
      justify-content: space-between;
      gap: 16px;
      padding: 16px 24px;
      border-bottom: 1px solid #2a3139;
      background: rgba(15, 20, 25, 0.35);
    }
    .filter-controls {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      flex: 1;
      min-width: 0;
    }
    .filter-field {
      display: flex;
      flex-direction: column;
      gap: 4px;
      min-width: 120px;
      flex: 1 1 140px;
    }
    .filter-field-search { flex: 2 1 180px; min-width: 160px; }
    .filter-label {
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #8b92a1;
    }
    .filter-input,
    .filter-select {
      background: #0f1419;
      border: 1px solid #2a3139;
      border-radius: 6px;
      color: #f0f1f3;
      font-size: 13px;
      padding: 8px 10px;
      width: 100%;
    }
    .filter-input:focus,
    .filter-select:focus {
      border-color: #64b5f6;
      outline: none;
    }
    .filter-count {
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 12px;
      color: #8b92a1;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .table-overflow { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; min-width: 920px; }
    th {
      padding: 16px;
      text-align: left;
      font-size: 11px;
      text-transform: uppercase;
      color: #8b92a1;
      border-bottom: 1px solid #2a3139;
      font-weight: 600;
      white-space: nowrap;
      cursor: pointer;
      user-select: none;
    }
    th:hover, th.active { color: #64b5f6; }
    .sort-indicator { margin-left: 4px; color: #64b5f6; font-size: 10px; }
    td { padding: 16px; border-bottom: 1px solid #2a3139; font-size: 14px; }
    tr[data-slug]:hover { background: rgba(100, 181, 246, 0.05); }
    tr.empty-state td {
      text-align: center;
      color: #8b92a1;
      font-style: italic;
      padding: 32px 16px;
    }
    .range-cell { color: #8b92a1; font-size: 13px; }
    .mono { font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 13px; }
  </style>
</head>
<body>
  <main class="container">
    <section class="hero">
      <div class="breadcrumb"><a href="/">Prominence Registry</a> / <a href="/lists/">Lists</a> / {definition.title}</div>
      <div class="eyebrow">Peak List</div>
      <h1>{definition.title}</h1>
      <p class="subtitle">{definition.description}</p>

      <div class="summary" aria-label="List summary">
        <div class="summary-card">
          <div class="summary-label">Peaks</div>
          <div class="summary-value">{peaks.length}</div>
        </div>
        <div class="summary-card">
          <div class="summary-label">Top Peak</div>
          <div class="summary-value">{peaks[0]?.name ?? '—'}</div>
        </div>
      </div>
    </section>

    <section class="table-wrapper" aria-labelledby="list-table-heading">
      <div class="table-header">
        <h2 id="list-table-heading">Ranked Peaks</h2>
        <p class="table-desc">Published guide pages are linked. Registry-only records are shown as plain text until their guide pages are ready.</p>
      </div>
      <div class="filter-bar">
        <div class="filter-controls">
          <label class="filter-field filter-field-search">
            <span class="filter-label">Search</span>
            <input
              type="search"
              id="peakFilterSearch"
              class="filter-input"
              placeholder="Peak or range…"
              autocomplete="off"
            />
          </label>
          <label class="filter-field">
            <span class="filter-label">State</span>
            <select id="peakFilterState" class="filter-select">
              <option value="all">All states</option>
              {listStates.map((state) => (
                <option value={state}>{state}</option>
              ))}
            </select>
          </label>
          <label class="filter-field">
            <span class="filter-label">Range</span>
            <select id="peakFilterRange" class="filter-select">
              <option value="all">All ranges</option>
              {listRanges.map((range) => (
                <option value={range}>{range}</option>
              ))}
            </select>
          </label>
          <label class="filter-field">
            <span class="filter-label">Class</span>
            <select id="peakFilterClass" class="filter-select">
              <option value="all">All classes</option>
              {listYdsClasses.map((ydsClass) => (
                <option value={ydsClass}>Class {ydsClass}</option>
              ))}
            </select>
          </label>
        </div>
        <p class="filter-count" id="peakFilterCount" aria-live="polite">
          Showing {peaks.length} of {peaks.length} peaks
        </p>
      </div>
      <div class="table-overflow">
        <table id="peakListTable">
          <thead>
            <tr>
              <th data-sort="listRank" class="active">List Rank <span class="sort-indicator">↑</span></th>
              <th data-sort="registryRank">Registry Rank <span class="sort-indicator"></span></th>
              <th data-sort="name">Peak <span class="sort-indicator"></span></th>
              <th data-sort="state">State <span class="sort-indicator"></span></th>
              <th data-sort="mountainRange">Range <span class="sort-indicator"></span></th>
              <th data-sort="elevation">Elevation <span class="sort-indicator"></span></th>
              <th data-sort="prominence">Prominence <span class="sort-indicator"></span></th>
              <th data-sort="isolation">Isolation <span class="sort-indicator"></span></th>
              <th data-sort="easiestYdsClass">Class <span class="sort-indicator"></span></th>
            </tr>
          </thead>
          <tbody id="peakListTableBody">
            {peaks.map((peak, index) => (
              <tr data-slug={peak.slug}>
                <td class="mono">{getRankLabel(index)}</td>
                <td class="mono">#{prominenceRankBySlug.get(peak.slug)}</td>
                <td>
                  {peak.published === true ? (
                    <a href={`/${peak.slug}/`}>{peak.name}</a>
                  ) : (
                    peak.name
                  )}
                </td>
                <td>{peak.state}</td>
                <td class="range-cell">{peak.mountainRange}</td>
                <td>{peak.elevation.toLocaleString()} ft</td>
                <td>{peak.prominence.toLocaleString()} ft</td>
                <td>{peak.isolation ?? '—'} mi</td>
                <td>{peak.easiestYdsClass}</td>
              </tr>
            ))}
            <tr id="peakListEmptyState" class="empty-state" hidden>
              <td colspan="9">No peaks match the current filters.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>
  </main>
  <SiteFooter />
  <script define:vars={{ peaks, prominenceRankBySlug: Object.fromEntries(prominenceRankBySlug), totalPeaks: peaks.length }}>
    const CLASS_ORDER = { '1': 1, '2': 2, '2+': 2.5, '3': 3, '3+': 3.5, '4': 4, '4+': 4.5, '5': 5 };
    const rankMap = prominenceRankBySlug;
    const listRankMap = Object.fromEntries(peaks.map((peak, index) => [peak.slug, index + 1]));
    let sortColumn = 'listRank';
    let sortDir = 'asc';

    const searchInput = document.getElementById('peakFilterSearch');
    const stateSelect = document.getElementById('peakFilterState');
    const rangeSelect = document.getElementById('peakFilterRange');
    const classSelect = document.getElementById('peakFilterClass');
    const countEl = document.getElementById('peakFilterCount');
    const emptyRow = document.getElementById('peakListEmptyState');

    function getSortValue(peak, column) {
      switch (column) {
        case 'listRank':
          return listRankMap[peak.slug] ?? 9999;
        case 'registryRank':
          return rankMap[peak.slug] ?? 9999;
        case 'name':
          return peak.name.toLowerCase();
        case 'state':
          return peak.state;
        case 'mountainRange':
          return (peak.mountainRange || '').toLowerCase();
        case 'elevation':
          return peak.elevation;
        case 'prominence':
          return peak.prominence;
        case 'isolation':
          return peak.isolation ?? -1;
        case 'easiestYdsClass':
          return CLASS_ORDER[peak.easiestYdsClass] ?? 0;
        default:
          return 0;
      }
    }

    function comparePeaks(a, b) {
      const aVal = getSortValue(a, sortColumn);
      const bVal = getSortValue(b, sortColumn);
      let result = 0;

      if (typeof aVal === 'string') {
        result = aVal.localeCompare(bVal);
      } else {
        result = aVal - bVal;
      }

      return sortDir === 'asc' ? result : -result;
    }

    function getFilteredPeaks() {
      const search = searchInput.value.trim().toLowerCase();
      const state = stateSelect.value;
      const range = rangeSelect.value;
      const ydsClass = classSelect.value;

      return peaks.filter((peak) => {
        if (search) {
          const nameMatch = peak.name.toLowerCase().includes(search);
          const rangeMatch = (peak.mountainRange || '').toLowerCase().includes(search);
          if (!nameMatch && !rangeMatch) return false;
        }
        if (state !== 'all' && peak.state !== state) return false;
        if (range !== 'all' && peak.mountainRange !== range) return false;
        if (ydsClass !== 'all' && peak.easiestYdsClass !== ydsClass) return false;
        return true;
      });
    }

    function updateSortIndicators() {
      document.querySelectorAll('#peakListTable th[data-sort]').forEach((th) => {
        const col = th.dataset.sort;
        const indicator = th.querySelector('.sort-indicator');
        const isActive = col === sortColumn;

        th.classList.toggle('active', isActive);
        indicator.textContent = isActive ? (sortDir === 'asc' ? '↑' : '↓') : '';
      });
    }

    function updateResultCount(visibleCount) {
      countEl.textContent = `Showing ${visibleCount} of ${totalPeaks} peaks`;
    }

    function applyFiltersAndSort() {
      const filtered = getFilteredPeaks();
      const sorted = [...filtered].sort(comparePeaks);
      const tbody = document.getElementById('peakListTableBody');
      const rowBySlug = new Map();

      tbody.querySelectorAll('tr[data-slug]').forEach((row) => {
        rowBySlug.set(row.dataset.slug, row);
        row.hidden = true;
      });

      if (sorted.length === 0) {
        emptyRow.hidden = false;
        tbody.appendChild(emptyRow);
      } else {
        emptyRow.hidden = true;
        sorted.forEach((peak) => {
          const row = rowBySlug.get(peak.slug);
          if (row) {
            row.hidden = false;
            tbody.appendChild(row);
          }
        });
        tbody.appendChild(emptyRow);
      }

      updateResultCount(sorted.length);
      updateSortIndicators();
    }

    document.querySelectorAll('#peakListTable th[data-sort]').forEach((th) => {
      th.addEventListener('click', () => {
        const col = th.dataset.sort;

        if (sortColumn === col) {
          sortDir = sortDir === 'asc' ? 'desc' : 'asc';
        } else {
          sortColumn = col;
          sortDir = col === 'listRank' || col === 'registryRank' || col === 'name' || col === 'state' || col === 'mountainRange' ? 'asc' : 'desc';
        }

        applyFiltersAndSort();
      });
    });

    [searchInput, stateSelect, rangeSelect, classSelect].forEach((control) => {
      control.addEventListener('input', applyFiltersAndSort);
      control.addEventListener('change', applyFiltersAndSort);
    });
  </script>
</body>
</html>
