---
import peaksData from '../data/peaks.json';
import imageTracking from '../data/image-tracking.json';
import { getCardImage } from '../utils/imageHelpers';

const peaksWithImages = peaksData.filter((peak) =>
  imageTracking.peaks.find((entry) => entry.slug === peak.slug)?.needs_image === 'no'
);
const featuredPeaks = peaksWithImages.slice(0, 3);
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Prominence Registry</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: #0f1419; color: #f0f1f3; font-family: system-ui; }
    .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
    .hero { padding: 96px 0; text-align: center; }
    .badge { display: inline-block; padding: 6px 12px; background: #1a1f27; border: 1px solid #2a3139; color: #64b5f6; font-size: 12px; border-radius: 20px; margin-bottom: 24px; }
    h1 { font-size: 56px; font-weight: 700; margin-bottom: 24px; }
    .subtitle { font-size: 18px; color: #8b92a1; max-width: 600px; margin: 0 auto 32px; line-height: 1.6; }
    .cta { display: inline-block; background: #64b5f6; color: #0f1419; padding: 12px 32px; border-radius: 8px; font-weight: 600; text-decoration: none; margin-right: 16px; }
    .cta:hover { opacity: 0.9; }
    .section { padding: 64px 0; }
    h2 { font-size: 32px; margin-bottom: 32px; }
    .featured-section { padding: 64px 0; }
    .featured-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 32px;
    }
    .featured-header h2 { font-size: 32px; margin: 0; }
    .carousel-controls { display: flex; gap: 12px; }
    .carousel-btn {
      width: 40px;
      height: 40px;
      background: #64b5f6;
      color: #0f1419;
      border: none;
      border-radius: 6px;
      font-size: 18px;
      font-weight: bold;
      cursor: pointer;
      transition: opacity 0.2s;
    }
    .carousel-btn:hover:not(:disabled) { opacity: 0.8; }
    .carousel-btn:disabled { opacity: 0.4; cursor: not-allowed; }
    .carousel-container {
      position: relative;
      max-width: 600px;
      margin: 0 auto;
    }
    .featured-carousel { margin-bottom: 0; }
    .carousel-viewport { display: grid; width: 100%; }
    .carousel-slide {
      grid-area: 1 / 1;
      opacity: 0;
      visibility: hidden;
      transition: opacity 500ms ease, visibility 500ms ease;
      pointer-events: none;
    }
    .carousel-slide.active {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
    }
    .featured-card {
      background: #1a1f27;
      border: 1px solid #2a3139;
      border-radius: 12px;
      overflow: hidden;
      text-decoration: none;
      color: inherit;
      display: block;
    }
    .featured-card:hover { border-color: #64b5f6; }
    .card-image-container {
      position: relative;
      width: 100%;
      height: 280px;
      overflow: hidden;
      background: #0b0f12;
    }
    .card-image-container picture { display: block; width: 100%; height: 100%; }
    .card-image-container img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .rank-badge {
      position: absolute;
      top: 12px;
      left: 12px;
      background: rgba(15, 20, 25, 0.85);
      border: 1px solid #2a3139;
      color: #64b5f6;
      padding: 6px 12px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1px;
      text-transform: uppercase;
      border-radius: 4px;
    }
    .card-content { padding: 20px; }
    .card-content h3 { font-size: 18px; font-weight: 600; margin: 0 0 8px; color: #f0f1f3; }
    .card-location { font-size: 12px; color: #8b92a1; margin: 0 0 16px; }
    .card-stats {
      display: flex;
      justify-content: space-around;
      align-items: center;
      gap: 0;
      padding: 0 4px;
    }
    .stat-column {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 0 12px;
      border-right: 1px solid #2a3139;
    }
    .stat-column:last-child { border-right: none; }
    .stat-label {
      font-size: 9px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #8b92a1;
      margin-bottom: 6px;
    }
    .stat-value { font-size: 14px; font-weight: 600; color: #f0f1f3; }
    .table-wrapper { background: #1a1f27; border: 1px solid #2a3139; border-radius: 12px; overflow: hidden; }
    .table-header { padding: 24px; border-bottom: 1px solid #2a3139; }
    .table-desc { color: #8b92a1; font-size: 14px; margin-top: 8px; }
    .table-overflow { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; min-width: 960px; }
    th { padding: 16px; text-align: left; font-size: 11px; text-transform: uppercase; color: #8b92a1; border-bottom: 1px solid #2a3139; font-weight: 600; cursor: pointer; user-select: none; white-space: nowrap; }
    th:hover, th.active { color: #64b5f6; }
    td { padding: 16px; border-bottom: 1px solid #2a3139; font-size: 14px; }
    tr:hover { background: rgba(100, 181, 246, 0.05); }
    a { color: #64b5f6; text-decoration: none; }
    a:hover { text-decoration: underline; }
    .sort-indicator { margin-left: 4px; color: #64b5f6; font-size: 10px; }
    .difficulty-badge { display: inline-flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 50%; background: #2a3139; font-size: 11px; font-weight: 700; }
    .permit-required { color: #f97316; font-size: 10px; font-weight: 700; text-transform: uppercase; }
    .permit-no { color: #5a6271; font-size: 10px; font-weight: 700; text-transform: uppercase; }
    .range-cell { color: #8b92a1; font-size: 13px; }
  </style>
</head>
<body>
  <div class="container">
    <div class="hero">
      <div class="badge">Live Elevation Data</div>
      <h1>Prominence Registry</h1>
      <p class="subtitle">Precision data for high-altitude exploration. Access the definitive database for ultra-prominent peaks.</p>
      <a href="#database" class="cta">Browse all peaks</a>
    </div>

    <section class="featured-section">
      <div class="featured-header">
        <h2>Featured Peaks</h2>
        <div class="carousel-controls">
          <button type="button" id="prev-peak" class="carousel-btn" aria-label="Previous peak" disabled>←</button>
          <button type="button" id="next-peak" class="carousel-btn" aria-label="Next peak" disabled={featuredPeaks.length <= 1}>→</button>
        </div>
      </div>
      <div class="carousel-container" id="featuredCarousel">
        <div class="carousel-viewport">
          {featuredPeaks.map((peak, index) => (
            <a
              href={`/${peak.slug}`}
              class:list={['featured-card', 'carousel-slide', { active: index === 0 }]}
              data-index={index}
            >
              <div class="card-image-container">
                <Fragment set:html={getCardImage(peak.slug, { alt: peak.name })} />
                <div class="rank-badge">RANK #{String(index + 1).padStart(2, '0')}</div>
              </div>
              <div class="card-content">
                <h3>{peak.name}</h3>
                <p class="card-location">{peak.state} • {peak.mountainRange}</p>
                <div class="card-stats">
                  <div class="stat-column">
                    <span class="stat-label">Elevation</span>
                    <span class="stat-value">{peak.elevation.toLocaleString()} ft</span>
                  </div>
                  <div class="stat-column">
                    <span class="stat-label">Range</span>
                    <span class="stat-value">{peak.mountainRange}</span>
                  </div>
                  <div class="stat-column">
                    <span class="stat-label">Prominence</span>
                    <span class="stat-value">{peak.prominence.toLocaleString()} ft</span>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <div class="section" id="database">
      <div class="table-wrapper">
        <div class="table-header">
          <h2>Technical Database</h2>
          <p class="table-desc">All 57 Ultra-prominent peaks. Click column headers to sort.</p>
        </div>
        <div class="table-overflow">
          <table id="peakTable">
            <thead>
              <tr>
                <th data-sort="name">Peak Name <span class="sort-indicator"></span></th>
                <th data-sort="state">State <span class="sort-indicator"></span></th>
                <th data-sort="mountainRange">Mountain Range <span class="sort-indicator"></span></th>
                <th data-sort="elevation">Elevation (ft) <span class="sort-indicator"></span></th>
                <th data-sort="prominence" class="active">Prominence (ft) <span class="sort-indicator">↓</span></th>
                <th data-sort="difficulty">Difficulty <span class="sort-indicator"></span></th>
                <th data-sort="ydsClass">Class <span class="sort-indicator"></span></th>
                <th data-sort="permitRequired">Permit <span class="sort-indicator"></span></th>
              </tr>
            </thead>
            <tbody id="tableBody">
              {peaksData.map(peak => (
                <tr data-slug={peak.slug}>
                  <td><a href={`/${peak.slug}`}>{peak.name}</a></td>
                  <td>{peak.state}</td>
                  <td class="range-cell">{peak.mountainRange}</td>
                  <td>{peak.elevation.toLocaleString()}</td>
                  <td>{peak.prominence.toLocaleString()}</td>
                  <td><div class="difficulty-badge">{peak.difficulty}</div></td>
                  <td>{peak.class}</td>
                  <td class={peak.permitRequired ? 'permit-required' : 'permit-no'}>{peak.permitRequired ? 'Required' : 'No'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <script define:vars={{ featuredPeaksCount: featuredPeaks.length }}>
    const carousel = document.getElementById('featuredCarousel');
    const prevBtn = document.getElementById('prev-peak');
    const nextBtn = document.getElementById('next-peak');

    if (carousel && prevBtn && nextBtn && featuredPeaksCount > 0) {
      const slides = carousel.querySelectorAll('.carousel-slide');
      let currentIndex = 0;
      let autoPlayInterval = null;
      let resumeTimeout = null;

      function updateButtons() {
        prevBtn.disabled = currentIndex === 0;
        nextBtn.disabled = currentIndex === featuredPeaksCount - 1;
      }

      function showSlide(index) {
        if (index < 0 || index >= featuredPeaksCount) return;
        currentIndex = index;
        slides.forEach((slide, i) => slide.classList.toggle('active', i === currentIndex));
        updateButtons();
      }

      function nextSlide() {
        if (currentIndex < featuredPeaksCount - 1) {
          showSlide(currentIndex + 1);
        }
      }

      function prevSlide() {
        if (currentIndex > 0) {
          showSlide(currentIndex - 1);
        }
      }

      function stopAutoPlay() {
        if (autoPlayInterval !== null) {
          window.clearInterval(autoPlayInterval);
          autoPlayInterval = null;
        }
      }

      function startAutoPlay() {
        stopAutoPlay();
        if (featuredPeaksCount <= 1) return;
        autoPlayInterval = window.setInterval(() => {
          if (currentIndex < featuredPeaksCount - 1) {
            nextSlide();
          } else {
            stopAutoPlay();
          }
        }, 15000);
      }

      function pauseAndScheduleResume() {
        stopAutoPlay();
        if (resumeTimeout !== null) {
          window.clearTimeout(resumeTimeout);
        }
        resumeTimeout = window.setTimeout(() => {
          resumeTimeout = null;
          startAutoPlay();
        }, 5000);
      }

      prevBtn.addEventListener('click', () => {
        prevSlide();
        pauseAndScheduleResume();
      });

      nextBtn.addEventListener('click', () => {
        nextSlide();
        pauseAndScheduleResume();
      });

      showSlide(0);
      startAutoPlay();
    }
  </script>

  <script define:vars={{ peaksData }}>
    const CLASS_ORDER = { '1': 1, '2': 2, '2+': 2.5, '3': 3, '3+': 3.5, '4': 4, '4+': 4.5, '5': 5 };
    let sortColumn = 'prominence';
    let sortDir = 'desc';

    function getSortValue(peak, column) {
      switch (column) {
        case 'name':
          return peak.name.toLowerCase();
        case 'state':
          return peak.state;
        case 'mountainRange':
          return (peak.mountainRange || '').toLowerCase();
        case 'elevation':
          return peak.elevation;
        case 'prominence':
          return peak.prominence;
        case 'difficulty':
          return peak.difficulty;
        case 'ydsClass':
          return CLASS_ORDER[peak.class] ?? 0;
        case 'permitRequired':
          return peak.permitRequired ? 1 : 0;
        default:
          return 0;
      }
    }

    function comparePeaks(a, b) {
      const aVal = getSortValue(a, sortColumn);
      const bVal = getSortValue(b, sortColumn);
      let result = 0;

      if (typeof aVal === 'string') {
        result = aVal.localeCompare(bVal);
      } else {
        result = aVal - bVal;
      }

      return sortDir === 'asc' ? result : -result;
    }

    function sortTableRows() {
      const tbody = document.getElementById('tableBody');
      const rowBySlug = new Map();

      tbody.querySelectorAll('tr[data-slug]').forEach((row) => {
        rowBySlug.set(row.dataset.slug, row);
      });

      const sorted = [...peaksData].sort(comparePeaks);
      sorted.forEach((peak) => {
        const row = rowBySlug.get(peak.slug);
        if (row) tbody.appendChild(row);
      });

      updateSortIndicators();
    }

    function updateSortIndicators() {
      document.querySelectorAll('#peakTable th[data-sort]').forEach(th => {
        const col = th.dataset.sort;
        const indicator = th.querySelector('.sort-indicator');
        const isActive = col === sortColumn;

        th.classList.toggle('active', isActive);
        indicator.textContent = isActive ? (sortDir === 'asc' ? '↑' : '↓') : '';
      });
    }

    document.querySelectorAll('#peakTable th[data-sort]').forEach(th => {
      th.addEventListener('click', () => {
        const col = th.dataset.sort;

        if (sortColumn === col) {
          sortDir = sortDir === 'asc' ? 'desc' : 'asc';
        } else {
          sortColumn = col;
          sortDir = col === 'name' || col === 'state' || col === 'mountainRange' ? 'asc' : 'desc';
        }

        sortTableRows();
      });
    });
  </script>
</body>
</html>
