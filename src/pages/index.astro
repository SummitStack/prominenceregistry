---
import peaksData from '../data/peaks.json';
import imageTracking from '../data/image-tracking.json';
import { getCardImage, hasPeakImages } from '../utils/imageHelpers';
import OrganizationSchema from '../components/OrganizationSchema.astro';
import FathomAnalytics from '../components/FathomAnalytics.astro';
import SeoMeta from '../components/SeoMeta.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { SITE_URL } from '../lib/constants';

const featuredPeaks = peaksData.filter(
  (peak) =>
    imageTracking.peaks.find((entry) => entry.slug === peak.slug)?.needs_image === 'no' &&
    hasPeakImages(peak.slug)
);
const prominenceRankBySlug = new Map(peaksData.map((peak, index) => [peak.slug, index + 1]));
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <FathomAnalytics />
  <SeoMeta
    title="Ultra-Prominent Peaks of the Lower 48 | Prominence Registry"
    description="Explore the Prominence Registry, a guide to the 57 ultra-prominent peaks of the contiguous United States with elevation, prominence, key col, isolation, route class, permits, and planning notes."
    ogDescription="Explore the 57 ultra-prominent peaks of the contiguous United States with prominence, elevation, key col, isolation, route class, permits, and planning notes."
    canonical={`${SITE_URL}/`}
  />
  <OrganizationSchema />
  <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: #0f1419; color: #f0f1f3; font-family: system-ui; }
    .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
    .hero { padding: 64px 0 96px; text-align: center; }
    h1 { font-size: 56px; font-weight: 700; margin-bottom: 24px; }
    .subtitle { font-size: 18px; color: #8b92a1; max-width: 600px; margin: 0 auto 32px; line-height: 1.6; }
    .cta { display: inline-block; background: #64b5f6; color: #0f1419; padding: 12px 32px; border-radius: 8px; font-weight: 600; text-decoration: none; margin-right: 16px; }
    .cta:hover { opacity: 0.9; }
    .section { padding: 64px 0; }
    h2 { font-size: 32px; margin-bottom: 32px; }
    .featured-section { padding: 80px 0; }
    .featured-header {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      align-items: flex-start;
      gap: 16px;
      margin-bottom: 48px;
    }
    @media (min-width: 768px) {
      .featured-header {
        flex-direction: row;
        align-items: flex-end;
      }
    }
    .featured-header-text h2 {
      font-family: 'Hanken Grotesk', system-ui, sans-serif;
      font-size: 40px;
      font-weight: 600;
      line-height: 1.2;
      margin: 0 0 8px;
      color: #e0e2e8;
    }
    .featured-header-text p {
      font-size: 16px;
      line-height: 1.6;
      color: #c0c7d1;
      margin: 0;
    }
    .carousel-controls { display: flex; gap: 8px; }
    .carousel-btn {
      width: auto;
      height: auto;
      padding: 8px;
      background: transparent;
      color: #e0e2e8;
      border: 1px solid #2a3139;
      border-radius: 8px;
      font-size: 20px;
      line-height: 1;
      font-weight: normal;
      cursor: pointer;
      transition: background 0.15s ease, border-color 0.15s ease;
    }
    .carousel-btn:hover:not(:disabled) { background: #1c2024; }
    .carousel-btn:disabled { opacity: 0.4; cursor: not-allowed; }
    .carousel-container {
      position: relative;
      width: 100%;
      margin: 0 auto;
    }
    .carousel-window { overflow: hidden; width: 100%; }
    .carousel-track {
      display: flex;
      gap: 32px;
      transition: transform 500ms ease;
      will-change: transform;
    }
    .featured-card {
      flex: 0 0 100%;
      min-width: 0;
      background: #181c20;
      border: 1px solid #2a3139;
      border-radius: 12px;
      overflow: hidden;
      text-decoration: none;
      color: inherit;
      display: block;
      transition: border-color 0.3s ease;
    }
    @media (min-width: 768px) {
      .featured-card { flex: 0 0 calc((100% - 64px) / 3); }
    }
    .featured-card:hover { border-color: rgba(100, 181, 246, 0.5); text-decoration: none; }
    .card-image-container {
      position: relative;
      width: 100%;
      height: 256px;
      overflow: hidden;
      background: #0b0f12;
    }
    .card-image-container :global(picture) {
      position: absolute;
      inset: 0;
      display: block;
      width: 100%;
      height: 100%;
    }
    .card-image-container :global(img) {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      max-width: none;
      object-fit: cover;
      object-position: center;
      display: block;
      transition: transform 0.5s ease;
    }
    .featured-card:hover .card-image-container :global(img) { transform: scale(1.05); }
    .rank-badge {
      position: absolute;
      top: 16px;
      left: 16px;
      background: rgba(49, 53, 57, 0.8);
      backdrop-filter: blur(8px);
      border: 1px solid #2a3139;
      color: #64b5f6;
      padding: 4px 12px;
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      border-radius: 4px;
    }
    .card-content { padding: 24px; }
    .card-content h3 {
      font-family: 'Hanken Grotesk', system-ui, sans-serif;
      font-size: 28px;
      font-weight: 600;
      line-height: 1.3;
      margin: 0;
      color: #e0e2e8;
    }
    .card-stats {
      display: flex;
      flex-wrap: wrap;
      gap: 16px;
      margin-top: 16px;
    }
    .stat-column {
      display: flex;
      flex-direction: column;
    }
    .stat-column + .stat-column {
      border-left: 1px solid #404850;
      padding-left: 16px;
    }
    .stat-label {
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 12px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #c0c7d1;
      margin-bottom: 4px;
    }
    .stat-value {
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 14px;
      font-weight: 400;
      line-height: 1;
      color: #64b5f6;
    }
    .table-wrapper { background: #1a1f27; border: 1px solid #2a3139; border-radius: 12px; overflow: hidden; }
    .table-header { padding: 24px; border-bottom: 1px solid #2a3139; }
    .table-desc { color: #8b92a1; font-size: 14px; margin-top: 8px; }
    .table-overflow { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; min-width: 960px; }
    th { padding: 16px; text-align: left; font-size: 11px; text-transform: uppercase; color: #8b92a1; border-bottom: 1px solid #2a3139; font-weight: 600; cursor: pointer; user-select: none; white-space: nowrap; }
    th:hover, th.active { color: #64b5f6; }
    td { padding: 16px; border-bottom: 1px solid #2a3139; font-size: 14px; }
    tr:hover { background: rgba(100, 181, 246, 0.05); }
    a { color: #64b5f6; text-decoration: none; }
    a:hover { text-decoration: underline; }
    .sort-indicator { margin-left: 4px; color: #64b5f6; font-size: 10px; }
    .range-cell { color: #8b92a1; font-size: 13px; }
    .stats-section { padding: 0 0 80px; }
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }
    @media (min-width: 768px) {
      .stats-grid { grid-template-columns: repeat(4, 1fr); }
    }
    .stats-card {
      background: #1a1f27;
      border: 1px solid #2a3139;
      border-radius: 12px;
      padding: 24px;
      text-align: center;
    }
    .stats-number {
      font-family: 'Hanken Grotesk', system-ui, sans-serif;
      font-size: 40px;
      font-weight: 700;
      line-height: 1.1;
      color: #64b5f6;
      margin-bottom: 8px;
    }
    .stats-card-label {
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 12px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #c0c7d1;
    }
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      vertical-align: middle;
    }
    .profile-callout {
      background: #0b0f12;
      border-top: 1px solid #404850;
      border-bottom: 1px solid #404850;
      padding: 80px 0;
    }
    .profile-callout-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 16px;
    }
    @media (min-width: 768px) {
      .profile-callout-inner { padding: 0 48px; }
    }
    .profile-callout-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 64px;
      align-items: center;
    }
    @media (min-width: 1024px) {
      .profile-callout-grid { grid-template-columns: 1fr 1fr; }
    }
    .profile-preview-wrap {
      position: relative;
    }
    .profile-preview-wrap::before {
      content: '';
      position: absolute;
      inset: -16px;
      background: rgba(100, 181, 246, 0.1);
      filter: blur(48px);
      border-radius: 9999px;
      opacity: 0;
      transition: opacity 0.7s ease;
      pointer-events: none;
    }
    .profile-preview-wrap:hover::before { opacity: 1; }
    .profile-preview-card {
      position: relative;
      background: #181c20;
      border: 1px solid #404850;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }
    .profile-preview-header {
      padding: 16px;
      border-bottom: 1px solid #404850;
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: #1a1f27;
    }
    .profile-preview-dots {
      display: flex;
      gap: 6px;
    }
    .profile-preview-dots span {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: #404850;
    }
    .profile-preview-label {
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #c0c7d1;
    }
    .profile-preview-body { padding: 24px; }
    .profile-preview-body > * + * { margin-top: 24px; }
    .profile-preview-image {
      position: relative;
      aspect-ratio: 16 / 9;
      border-radius: 8px;
      overflow: hidden;
      border: 1px solid #404850;
      background: #0b0f12;
    }
    .profile-preview-image :global(picture),
    .profile-preview-image :global(img) {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .profile-preview-stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }
    .profile-stat-box {
      padding: 12px;
      border-radius: 6px;
      background: #1a1f27;
      border: 1px solid #404850;
    }
    .profile-stat-label {
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 10px;
      text-transform: uppercase;
      color: #c0c7d1;
      margin-bottom: 4px;
    }
    .profile-stat-value {
      font-size: 14px;
      font-weight: 700;
      color: #64b5f6;
    }
    .profile-stat-value.neutral { color: #e0e2e8; }
    .profile-callout-title {
      font-family: 'Hanken Grotesk', system-ui, sans-serif;
      font-size: 36px;
      font-weight: 700;
      line-height: 1.15;
      color: #e0e2e8;
      margin-bottom: 24px;
    }
    @media (min-width: 768px) {
      .profile-callout-title { font-size: 44px; }
    }
    .profile-callout-desc {
      font-size: 18px;
      line-height: 1.6;
      color: #c0c7d1;
      margin-bottom: 40px;
    }
    .profile-features { display: flex; flex-direction: column; gap: 32px; }
    .profile-feature {
      display: flex;
      gap: 20px;
    }
    .profile-feature-icon {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      background: rgba(100, 181, 246, 0.1);
      border: 1px solid rgba(100, 181, 246, 0.2);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      color: #64b5f6;
    }
    .profile-feature h4 {
      font-weight: 700;
      color: #e0e2e8;
      margin-bottom: 4px;
      font-size: 16px;
    }
    .profile-feature p {
      font-size: 14px;
      line-height: 1.6;
      color: #c0c7d1;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="hero">
      <h1>Prominence Registry</h1>
      <p class="subtitle">Precision data for high-altitude exploration. Access the definitive database for ultra-prominent peaks.</p>
      <div class="flex justify-center">
        <a href="#database" class="cta">Browse all peaks</a>
      </div>
    </div>

    <section class="featured-section">
      <div class="featured-header">
        <div class="featured-header-text">
          <h2>Featured Peaks</h2>
          <p>Curated technical profiles for major prominence centers.</p>
        </div>
        <div class="carousel-controls">
          <button type="button" id="prev-peak" class="carousel-btn" aria-label="Previous peak" disabled>‹</button>
          <button type="button" id="next-peak" class="carousel-btn" aria-label="Next peak">›</button>
        </div>
      </div>
      <div class="carousel-container" id="featuredCarousel">
        <div class="carousel-window">
          <div class="carousel-track" id="carouselTrack">
            {featuredPeaks.map((peak) => (
              <a href={`/${peak.slug}/`} class="featured-card" data-slug={peak.slug}>
                <div class="card-image-container">
                  <Fragment set:html={getCardImage(peak.slug, {
                    alt: peak.name,
                    sizes: '(max-width: 767px) 100vw, 33vw',
                  })} />
                  <div class="rank-badge">
                    Rank #{String(prominenceRankBySlug.get(peak.slug) ?? 0).padStart(2, '0')}
                  </div>
                </div>
                <div class="card-content">
                  <h3>{peak.name}</h3>
                  <div class="card-stats">
                    <div class="stat-column">
                      <span class="stat-label">Elevation</span>
                      <span class="stat-value">{peak.elevation.toLocaleString()} ft</span>
                    </div>
                    <div class="stat-column">
                      <span class="stat-label">Prominence</span>
                      <span class="stat-value">{peak.prominence.toLocaleString()} ft</span>
                    </div>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  </div>

  <section class="profile-callout" aria-labelledby="profile-callout-heading">
    <div class="profile-callout-inner">
      <div class="profile-callout-grid">
        <div class="profile-preview-wrap">
          <div class="profile-preview-card">
            <div class="profile-preview-header">
              <div class="profile-preview-dots" aria-hidden="true">
                <span></span><span></span><span></span>
              </div>
              <div class="profile-preview-label">Peak Profile: Mt. Rainier</div>
            </div>
            <div class="profile-preview-body">
              <div class="profile-preview-image">
                <Fragment set:html={getCardImage('mount-rainier', {
                  alt: 'Mount Rainier peak profile preview',
                  sizes: '(max-width: 1024px) 100vw, 50vw',
                })} />
              </div>
              <div class="profile-preview-stats">
                <div class="profile-stat-box">
                  <div class="profile-stat-label">Elev</div>
                  <div class="profile-stat-value">14,406'</div>
                </div>
                <div class="profile-stat-box">
                  <div class="profile-stat-label">Prom</div>
                  <div class="profile-stat-value">13,257'</div>
                </div>
                <div class="profile-stat-box">
                  <div class="profile-stat-label">Class</div>
                  <div class="profile-stat-value neutral">4</div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div>
          <h2 id="profile-callout-heading" class="profile-callout-title">
            Deep profiles for every summit.
          </h2>
          <p class="profile-callout-desc">
            Each profile covers the complete technical anatomy of an ultra-prominent peak — elevation, prominence, standard route, permit status, and known hazards.
          </p>
          <div class="profile-features">
            <div class="profile-feature">
              <div class="profile-feature-icon">
                <span class="material-symbols-outlined">analytics</span>
              </div>
              <div>
                <h4>Technical Metadata</h4>
                <p>Elevation and prominence values from validated topographic surveys.</p>
              </div>
            </div>
            <div class="profile-feature">
              <div class="profile-feature-icon">
                <span class="material-symbols-outlined">route</span>
              </div>
              <div>
                <h4>Route Intelligence</h4>
                <p>Primary route descriptions including key landmarks and crux points.</p>
              </div>
            </div>
            <div class="profile-feature">
              <div class="profile-feature-icon">
                <span class="material-symbols-outlined">confirmation_number</span>
              </div>
              <div>
                <h4>Permit Status</h4>
                <p>Current permit requirements and seasonal access restrictions.</p>
              </div>
            </div>
            <div class="profile-feature">
              <div class="profile-feature-icon">
                <span class="material-symbols-outlined">warning</span>
              </div>
              <div>
                <h4>Known Hazards</h4>
                <p>Critical terrain warnings and technical requirements for high-altitude environments.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="container">
    <div class="section" id="database">
      <div class="table-wrapper">
        <div class="table-header">
          <h2>Technical Database</h2>
          <p class="table-desc">All 57 Ultra-prominent peaks. Click column headers to sort.</p>
        </div>
        <div class="table-overflow">
          <table id="peakTable">
            <thead>
              <tr>
                <th data-sort="rank">Rank <span class="sort-indicator"></span></th>
                <th data-sort="name">Peak Name <span class="sort-indicator"></span></th>
                <th data-sort="state">State <span class="sort-indicator"></span></th>
                <th data-sort="mountainRange">Mountain Range <span class="sort-indicator"></span></th>
                <th data-sort="elevation">Elevation (ft) <span class="sort-indicator"></span></th>
                <th data-sort="prominence" class="active">Prominence (ft) <span class="sort-indicator">↓</span></th>
                <th data-sort="keyCol">Key Col (ft) <span class="sort-indicator"></span></th>
                <th data-sort="isolation">Isolation (mi) <span class="sort-indicator"></span></th>
                <th data-sort="ydsClass">Class <span class="sort-indicator"></span></th>
              </tr>
            </thead>
            <tbody id="tableBody">
              {peaksData.map(peak => (
                <tr data-slug={peak.slug}>
                  <td>{String(prominenceRankBySlug.get(peak.slug) ?? 0).padStart(2, '0')}</td>
                  <td><a href={`/${peak.slug}/`}>{peak.name}</a></td>
                  <td>{peak.state}</td>
                  <td class="range-cell">{peak.mountainRange}</td>
                  <td>{peak.elevation.toLocaleString()}</td>
                  <td>{peak.prominence.toLocaleString()}</td>
                  <td>{(peak.elevation - peak.prominence).toLocaleString()}</td>
                  <td>{peak.isolation}</td>
                  <td>{peak.ydsClass}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <section class="stats-section" aria-label="Site statistics">
      <div class="stats-grid">
        <div class="stats-card">
          <div class="stats-number">57</div>
          <div class="stats-card-label">Ultra-Prominent Peaks</div>
        </div>
        <div class="stats-card">
          <div class="stats-number">5,000 ft</div>
          <div class="stats-card-label">Min Prominence Threshold</div>
        </div>
        <div class="stats-card">
          <div class="stats-number">48</div>
          <div class="stats-card-label">States Covered</div>
        </div>
        <div class="stats-card">
          <div class="stats-number">1</div>
          <div class="stats-card-label">Organizing Standard</div>
        </div>
      </div>
    </section>
  </div>

  <script define:vars={{ featuredPeaksCount: featuredPeaks.length }}>
    const carousel = document.getElementById('featuredCarousel');
    const track = document.getElementById('carouselTrack');
    const prevBtn = document.getElementById('prev-peak');
    const nextBtn = document.getElementById('next-peak');

    if (carousel && track && prevBtn && nextBtn && featuredPeaksCount > 0) {
      let startIndex = 0;
      let autoPlayInterval = null;
      let resumeTimeout = null;

      function getVisibleCount() {
        return window.matchMedia('(min-width: 768px)').matches
          ? Math.min(3, featuredPeaksCount)
          : 1;
      }

      function maxStartIndex() {
        return Math.max(0, featuredPeaksCount - getVisibleCount());
      }

      function updateTrack() {
        const cards = track.querySelectorAll('.featured-card');
        if (!cards.length) return;

        const gap = 32;
        const cardWidth = cards[0].getBoundingClientRect().width;
        track.style.transform = `translateX(-${startIndex * (cardWidth + gap)}px)`;

        prevBtn.disabled = startIndex === 0;
        nextBtn.disabled = startIndex >= maxStartIndex();
      }

      function nextSlide() {
        if (startIndex < maxStartIndex()) {
          startIndex += 1;
          updateTrack();
        }
      }

      function prevSlide() {
        if (startIndex > 0) {
          startIndex -= 1;
          updateTrack();
        }
      }

      function stopAutoPlay() {
        if (autoPlayInterval !== null) {
          window.clearInterval(autoPlayInterval);
          autoPlayInterval = null;
        }
      }

      function startAutoPlay() {
        stopAutoPlay();
        if (featuredPeaksCount <= getVisibleCount()) return;
        autoPlayInterval = window.setInterval(() => {
          if (startIndex < maxStartIndex()) {
            nextSlide();
          } else {
            stopAutoPlay();
          }
        }, 15000);
      }

      function pauseAndScheduleResume() {
        stopAutoPlay();
        if (resumeTimeout !== null) {
          window.clearTimeout(resumeTimeout);
        }
        resumeTimeout = window.setTimeout(() => {
          resumeTimeout = null;
          startAutoPlay();
        }, 5000);
      }

      prevBtn.addEventListener('click', () => {
        prevSlide();
        pauseAndScheduleResume();
      });

      nextBtn.addEventListener('click', () => {
        nextSlide();
        pauseAndScheduleResume();
      });

      window.addEventListener('resize', () => {
        if (startIndex > maxStartIndex()) {
          startIndex = maxStartIndex();
        }
        updateTrack();
      });

      updateTrack();
      startAutoPlay();
    }
  </script>

  <script define:vars={{ peaksData, prominenceRankBySlug: Object.fromEntries(prominenceRankBySlug) }}>
    const CLASS_ORDER = { '1': 1, '2': 2, '2+': 2.5, '3': 3, '3+': 3.5, '4': 4, '4+': 4.5, '5': 5 };
    const rankMap = prominenceRankBySlug;
    let sortColumn = 'prominence';
    let sortDir = 'desc';

    function getSortValue(peak, column) {
      switch (column) {
        case 'rank':
          return rankMap[peak.slug] ?? 999;
        case 'name':
          return peak.name.toLowerCase();
        case 'state':
          return peak.state;
        case 'mountainRange':
          return (peak.mountainRange || '').toLowerCase();
        case 'elevation':
          return peak.elevation;
        case 'prominence':
          return peak.prominence;
        case 'keyCol':
          return peak.elevation - peak.prominence;
        case 'isolation':
          return peak.isolation;
        case 'ydsClass':
          return CLASS_ORDER[peak.ydsClass] ?? 0;
        default:
          return 0;
      }
    }

    function comparePeaks(a, b) {
      const aVal = getSortValue(a, sortColumn);
      const bVal = getSortValue(b, sortColumn);
      let result = 0;

      if (typeof aVal === 'string') {
        result = aVal.localeCompare(bVal);
      } else {
        result = aVal - bVal;
      }

      return sortDir === 'asc' ? result : -result;
    }

    function sortTableRows() {
      const tbody = document.getElementById('tableBody');
      const rowBySlug = new Map();

      tbody.querySelectorAll('tr[data-slug]').forEach((row) => {
        rowBySlug.set(row.dataset.slug, row);
      });

      const sorted = [...peaksData].sort(comparePeaks);
      sorted.forEach((peak) => {
        const row = rowBySlug.get(peak.slug);
        if (row) tbody.appendChild(row);
      });

      updateSortIndicators();
    }

    function updateSortIndicators() {
      document.querySelectorAll('#peakTable th[data-sort]').forEach(th => {
        const col = th.dataset.sort;
        const indicator = th.querySelector('.sort-indicator');
        const isActive = col === sortColumn;

        th.classList.toggle('active', isActive);
        indicator.textContent = isActive ? (sortDir === 'asc' ? '↑' : '↓') : '';
      });
    }

    document.querySelectorAll('#peakTable th[data-sort]').forEach(th => {
      th.addEventListener('click', () => {
        const col = th.dataset.sort;

        if (sortColumn === col) {
          sortDir = sortDir === 'asc' ? 'desc' : 'asc';
        } else {
          sortColumn = col;
          sortDir = col === 'name' || col === 'state' || col === 'mountainRange' || col === 'rank' ? 'asc' : 'desc';
        }

        sortTableRows();
      });
    });
  </script>
  <SiteFooter />
</body>
</html>
