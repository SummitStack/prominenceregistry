---

<footer class="site-footer">
  <div class="site-footer-inner">
    <div class="site-footer-grid">
      <div class="site-footer-brand-col">
        <div class="site-footer-title">Peak Directory</div>
        <p class="site-footer-desc">
          The Prominence Registry provides precision topographical data for serious high-altitude explorers.
        </p>
      </div>
      <div class="site-footer-nav-cols">
        <div>
          <h4 class="site-footer-nav-heading">Explore</h4>
          <nav class="site-footer-nav" aria-label="Explore">
            <a href="/#database">All Peaks Index</a>
            <a href="/glossary/">Glossary</a>
          </nav>
        </div>
        <div>
          <h4 class="site-footer-nav-heading">Site</h4>
          <nav class="site-footer-nav" aria-label="Site">
            <a href="/about/">About the Registry</a>
            <a href="mailto:info@prominenceregistry.com">Contact</a>
          </nav>
        </div>
      </div>
    </div>
    <div class="site-footer-bottom">
      <p class="site-footer-copy">
        © <span id="footer-year"></span> Prominence Registry. Precise topographic data for the high-altitude explorer.
      </p>
    </div>
  </div>
</footer>

<script is:inline>
  const yearEl = document.getElementById('footer-year');
  if (yearEl) yearEl.textContent = String(new Date().getFullYear());
</script>

<script is:inline>
  (() => {
    const mapPlaceholders = Array.from(document.querySelectorAll('.map-placeholder'));
    if (mapPlaceholders.length === 0) return;

    mapPlaceholders.forEach((mapEl) => {
      const locationArticle = mapEl.closest('article');
      const locationHeading = locationArticle?.querySelector('.section-title');
      const mapsLink = locationArticle?.querySelector('a[href*="google.com/maps/search"]');

      if (locationHeading) {
        const titleBar = locationHeading.querySelector('.section-title-bar');
        locationHeading.textContent = '';
        if (titleBar) locationHeading.appendChild(titleBar);
        locationHeading.append('Summit Location');
      }

      if (mapsLink) {
        mapsLink.setAttribute('rel', 'noopener noreferrer nofollow');
      }
    });

    function getCoordinatesFromMapsUrl(mapEl) {
      const locationArticle = mapEl.closest('article');
      const mapsLink = locationArticle?.querySelector('a[href*="google.com/maps/search"]');
      const href = mapsLink?.getAttribute('href');
      if (!href) return null;

      const match = href.match(/[?&]query=(-?\d+(?:\.\d+)?),(-?\d+(?:\.\d+)?)/);
      if (!match) return null;

      const latitude = Number(match[1]);
      const longitude = Number(match[2]);

      if (!Number.isFinite(latitude) || !Number.isFinite(longitude)) return null;
      return { latitude, longitude };
    }

    const summitMaps = mapPlaceholders
      .map((mapEl) => ({ mapEl, coordinates: getCoordinatesFromMapsUrl(mapEl) }))
      .filter(({ coordinates }) => coordinates !== null);

    if (summitMaps.length === 0) return;

    function loadStylesheet(href) {
      if (document.querySelector(`link[href="${href}"]`)) return;
      const link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = href;
      document.head.appendChild(link);
    }

    function loadScript(src) {
      return new Promise((resolve, reject) => {
        if (window.L) {
          resolve();
          return;
        }

        const existingScript = document.querySelector(`script[src="${src}"]`);
        if (existingScript) {
          existingScript.addEventListener('load', resolve, { once: true });
          existingScript.addEventListener('error', reject, { once: true });
          return;
        }

        const script = document.createElement('script');
        script.src = src;
        script.async = true;
        script.onload = resolve;
        script.onerror = reject;
        document.body.appendChild(script);
      });
    }

    let leafletReady;

    function prepareLeaflet() {
      if (!leafletReady) {
        loadStylesheet('https://unpkg.com/leaflet@1.9.4/dist/leaflet.css');
        leafletReady = loadScript('https://unpkg.com/leaflet@1.9.4/dist/leaflet.js');
      }
      return leafletReady;
    }

    async function initializeMap(mapEl, coordinates) {
      if (mapEl.dataset.mapInitialized === 'true') return;
      mapEl.dataset.mapInitialized = 'true';
      mapEl.setAttribute('aria-label', 'Interactive summit location map');

      try {
        await prepareLeaflet();
        if (!window.L) return;

        mapEl.innerHTML = '';
        mapEl.classList.add('summit-map-loaded');

        const map = window.L.map(mapEl, {
          attributionControl: true,
          zoomControl: true,
          scrollWheelZoom: false,
        }).setView([coordinates.latitude, coordinates.longitude], 10);

        window.L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          maxZoom: 18,
          attribution: '&copy; <a href="https://www.openstreetmap.org/copyright" target="_blank" rel="noopener noreferrer nofollow">OpenStreetMap</a> contributors',
        }).addTo(map);

        const peakName = document.querySelector('.page-title')?.textContent?.trim() ?? 'Summit location';
        const marker = window.L.marker([coordinates.latitude, coordinates.longitude]).addTo(map);
        marker.bindPopup(peakName);
      } catch (error) {
        mapEl.dataset.mapInitialized = 'false';
        console.warn('Unable to load summit map', error);
      }
    }

    const observer = 'IntersectionObserver' in window
      ? new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const match = summitMaps.find(({ mapEl }) => mapEl === entry.target);
            if (!match || !match.coordinates) return;
            initializeMap(match.mapEl, match.coordinates);
            observer.unobserve(entry.target);
          });
        }, { rootMargin: '250px 0px' })
      : null;

    summitMaps.forEach(({ mapEl, coordinates }) => {
      mapEl.classList.add('summit-map-pending');
      mapEl.dataset.latitude = String(coordinates.latitude);
      mapEl.dataset.longitude = String(coordinates.longitude);

      if (observer) {
        observer.observe(mapEl);
      } else {
        initializeMap(mapEl, coordinates);
      }
    });
  })();
</script>

<style>
  .site-footer {
    background: #181c20;
    border-top: 1px solid #404850;
  }
  .site-footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 64px 16px;
  }
  @media (min-width: 768px) {
    .site-footer-inner { padding: 64px 48px; }
  }
  .site-footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    margin-bottom: 48px;
  }
  @media (min-width: 768px) {
    .site-footer-grid { grid-template-columns: 1fr 2fr; }
  }
  .site-footer-brand-col { display: flex; flex-direction: column; gap: 24px; }
  .site-footer-title {
    font-family: 'Hanken Grotesk', system-ui, sans-serif;
    font-size: 24px;
    font-weight: 700;
    line-height: 1.2;
    color: #e0e2e8;
  }
  .site-footer-desc {
    font-size: 14px;
    line-height: 1.6;
    color: #c0c7d1;
    max-width: 20rem;
    margin: 0;
  }
  .site-footer-nav-cols {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }
  @media (min-width: 640px) {
    .site-footer-nav-cols { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 768px) {
    .site-footer-nav-cols { padding-left: 48px; }
  }
  .site-footer-nav-heading {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #64b5f6;
    margin: 0 0 24px;
  }
  .site-footer-nav {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .site-footer-nav a {
    color: #c0c7d1;
    text-decoration: none;
    font-size: 15px;
    transition: color 0.15s ease;
  }
  .site-footer-nav a:hover { color: #e0e2e8; }
  .site-footer-bottom {
    padding-top: 32px;
    border-top: 1px solid #404850;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  @media (min-width: 768px) {
    .site-footer-bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }
  .site-footer-copy {
    font-size: 14px;
    line-height: 1.6;
    color: #c0c7d1;
    margin: 0;
    text-align: center;
  }
  @media (min-width: 768px) {
    .site-footer-copy { text-align: left; }
  }
</style>

<style is:global>
  .summit-map-pending::after {
    content: 'Loading summit map';
    position: absolute;
    left: 50%;
    bottom: 24px;
    transform: translateX(-50%);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #c0c7d1;
  }

  .summit-map-loaded {
    background: #18212a;
  }

  .summit-map-loaded .leaflet-control-attribution,
  .summit-map-loaded .leaflet-control-zoom a {
    background: rgba(16, 20, 24, 0.88);
    color: #e0e2e8;
    border-color: #404850;
  }

  .summit-map-loaded .leaflet-control-attribution a {
    color: #9bcfff;
  }

  .summit-map-loaded .leaflet-popup-content-wrapper,
  .summit-map-loaded .leaflet-popup-tip {
    background: #181c20;
    color: #e0e2e8;
  }
</style>
