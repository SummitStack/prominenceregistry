{
  "name": "minor-mars",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "prebuild": "npm run validate:peaks && npm run validate:peak-content && npm run validate:peak-verification && npm run validate:seo-images && npm run validate:seo-meta && npx tsx scripts/prebuild-schema.ts",
    "build": "astro build",
    "postbuild": "npm run validate:structured-data && npm run validate:favicons",
    "preview": "astro preview",
    "astro": "astro",
    "validate:peaks": "npx tsx scripts/validatePeaks.ts",
    "validate:seo-images": "npx tsx scripts/validateSeoImages.ts",
    "validate:seo-meta": "npx tsx scripts/validateSeoMeta.ts",
    "validate:structured-data": "npx tsx scripts/validateStructuredData.ts",
    "validate:favicons": "npx tsx scripts/validateFavicons.ts",
    "generate:favicons": "node scripts/generate-favicons.mjs",
    "test": "npx tsx --test src/__tests__/schema.test.ts",
    "test:schema": "npm run test",
    "fetch-images": "node scripts/fetch-hero-images.js",
    "optimize-images": "node scripts/optimize-images.js",
    "fetch-weather-urls": "node scripts/apply-weather-urls.js",
    "validate:peak-content": "npx tsx scripts/validatePeakContent.ts",
    "validate:peak-verification": "npx tsx scripts/validatePeakVerification.ts"
  },
  "dependencies": {
    "astro": "^6.4.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.3.1"
  }
}
